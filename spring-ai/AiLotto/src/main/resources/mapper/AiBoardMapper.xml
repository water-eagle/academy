<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.watereagle.ai.mapper.AiBoardMapper">

	<delete id="del"> delete from ai_board where no=#{no} </delete>

	<select id="read" resultType="com.watereagle.ai.dto.Post"> SELECT * FROM ai_board WHERE no=#{no} </select>

	<select id="getList" resultType="Post">SELECT * FROM ai_board ORDER BY no DESC</select>
</mapper>
